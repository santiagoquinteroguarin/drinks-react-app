[{"/mnt/d/development/drinks-app/src/index.js":"1","/mnt/d/development/drinks-app/src/App.js":"2","/mnt/d/development/drinks-app/src/reportWebVitals.js":"3","/mnt/d/development/drinks-app/src/components/Header.js":"4","/mnt/d/development/drinks-app/src/components/Form.js":"5","/mnt/d/development/drinks-app/src/context/ContextCategories.js":"6","/mnt/d/development/drinks-app/src/context/ContextRecipes.js":"7","/mnt/d/development/drinks-app/src/components/ListRecipes.js":"8","/mnt/d/development/drinks-app/src/components/Recipe.js":"9"},{"size":530,"mtime":1607781194237,"results":"10","hashOfConfig":"11"},{"size":597,"mtime":1607788006224,"results":"12","hashOfConfig":"11"},{"size":362,"mtime":1607780557709,"results":"13","hashOfConfig":"11"},{"size":198,"mtime":1607781368191,"results":"14","hashOfConfig":"11"},{"size":2300,"mtime":1607787627772,"results":"15","hashOfConfig":"11"},{"size":977,"mtime":1607785429885,"results":"16","hashOfConfig":"11"},{"size":1274,"mtime":1607788048483,"results":"17","hashOfConfig":"11"},{"size":511,"mtime":1607788421225,"results":"18","hashOfConfig":"11"},{"size":676,"mtime":1607788814400,"results":"19","hashOfConfig":"11"},{"filePath":"20","messages":"21","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"1kouug1",{"filePath":"22","messages":"23","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"24","messages":"25","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"26","messages":"27","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"28"},{"filePath":"29","messages":"30","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"31","messages":"32","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"33","messages":"34","errorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"35","usedDeprecatedRules":"28"},{"filePath":"36","messages":"37","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"38","messages":"39","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"/mnt/d/development/drinks-app/src/index.js",[],"/mnt/d/development/drinks-app/src/App.js",[],"/mnt/d/development/drinks-app/src/reportWebVitals.js",[],"/mnt/d/development/drinks-app/src/components/Header.js",[],["40","41"],"/mnt/d/development/drinks-app/src/components/Form.js",[],"/mnt/d/development/drinks-app/src/context/ContextCategories.js",[],"/mnt/d/development/drinks-app/src/context/ContextRecipes.js",["42","43"],"import React, { createContext, useState, useEffect } from 'react';\nimport axios from 'axios';\n\n// crear context, siempre que se crea un context se necesita un provider\nexport const ContextRecipes = createContext();\n\n// provider --> de donde van a salir los datos(state) y las funciones.\nconst ProviderRecipes = (props) => {\n\n    // crear el state del context\n    const [recipes, setSavedRecipes] = useState([]);\n    const [search, setSearchRecipes] = useState({\n        name: '',\n        category: '',\n    });\n    const [consult, setSavedConsult] = useState(false);\n    const { name, category } = search;\n\n    useEffect(() => {\n        if(consult) {\n            const getRecipes = async () => {\n                const url = `https://www.thecocktaildb.com/api/json/v1/1/filter.php?i=${name}&c=${category}`;\n                const  response = await axios.get(url);\n\n                setSavedRecipes(response.data.drinks);\n            }\n            getRecipes();\n        }\n    }, [search]);\n\n    return (\n        <ContextRecipes.Provider\n            value={{\n                recipes,\n                setSearchRecipes,\n                setSavedConsult\n            }}\n        >\n            {props.children}\n        </ContextRecipes.Provider>\n    );\n}\n\nexport default ProviderRecipes;","/mnt/d/development/drinks-app/src/components/ListRecipes.js",[],"/mnt/d/development/drinks-app/src/components/Recipe.js",[],{"ruleId":"44","replacedBy":"45"},{"ruleId":"46","replacedBy":"47"},{"ruleId":"48","severity":1,"message":"49","line":11,"column":12,"nodeType":"50","messageId":"51","endLine":11,"endColumn":19},{"ruleId":"52","severity":1,"message":"53","line":29,"column":8,"nodeType":"54","endLine":29,"endColumn":16,"suggestions":"55"},"no-native-reassign",["56"],"no-negated-in-lhs",["57"],"no-unused-vars","'recipes' is assigned a value but never used.","Identifier","unusedVar","react-hooks/exhaustive-deps","React Hook useEffect has missing dependencies: 'category', 'consult', and 'name'. Either include them or remove the dependency array.","ArrayExpression",["58"],"no-global-assign","no-unsafe-negation",{"desc":"59","fix":"60"},"Update the dependencies array to be: [category, consult, name, search]",{"range":"61","text":"62"},[974,982],"[category, consult, name, search]"]